# ==============================================================================
# FlowBoard Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values for your environment.
# Variables marked "Required" must be set for the app to start.
# Variables marked "Optional" have sensible defaults.
# ==============================================================================

# Required. PostgreSQL connection string used by Prisma ORM.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
# The schema parameter isolates FlowBoard tables in the given Postgres schema.
DATABASE_URL="postgresql://flowboard:flowboard@localhost:5432/flowboard?schema=public"

# Optional. Redis host for caching, Bull queues, pub/sub, and refresh-token storage.
# Default: localhost
REDIS_HOST=localhost

# Optional. Redis port number.
# Default: 6379
REDIS_PORT=6379

# Required. Secret key used to sign and verify JWT access and refresh tokens.
# Must be a long, random string in production. Never commit a real secret.
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Optional. Lifetime of JWT access tokens (short-lived).
# Format: vercel/ms duration string (e.g., 15m, 1h, 30s).
# Default: 15m
JWT_ACCESS_EXPIRATION=15m

# Optional. Lifetime of JWT refresh tokens (long-lived, stored in Redis).
# Format: vercel/ms duration string (e.g., 7d, 30d).
# Default: 7d
JWT_REFRESH_EXPIRATION=7d

# Optional. Port the NestJS API server listens on.
# Default: 3001
API_PORT=3001

# Optional. Port the Next.js web app dev server listens on.
# Default: 3000
WEB_PORT=3000

# Optional. Internal base URL of the API (used by server-side code).
# Default: http://localhost:3001
API_URL=http://localhost:3001

# Required (client-side). Public base URL of the API, embedded in the browser bundle.
# Must match the API's actual URL as seen by the user's browser.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Required (client-side). Public WebSocket URL for Socket.IO connections.
# Typically the same as NEXT_PUBLIC_API_URL since the gateway shares the API port.
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Optional. Allowed CORS origin for the API. Set to the web app's URL.
# In production, set to your actual domain (e.g., https://flowboard.dev).
# Default: http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Optional. Anthropic API key for AI-powered task parsing via the command palette.
# Features degrade gracefully without this key (AI parsing is simply disabled).
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
